# MiniMax API Configuration
# 请在 Vercel 后台 → Settings → Environment Variables 中配置以下变量

VITE_MINIMAX_API_KEY=你的MiniMax_API密钥
VITE_MINIMAX_BASE_URL=https://api.minimax.chat/v1
VITE_MINIMAX_MODEL=minimax-m2.7

# PC配件价格API后端配置
# 本地开发: http://localhost:5000
# Vercel部署: https://your-vercel-url.vercel.app
VUE_APP_API_URL=http://localhost:5000
